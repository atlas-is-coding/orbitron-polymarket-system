[[wallets]]
  id = "0f5b5505285e5ac3"
  label = "Default"
  # Required. Set here or via env var POLY_PRIVATE_KEY
  private_key = ""
  # Required. Set here or via env var POLY_API_KEY
  api_key = ""
  # Required. Set here or via env var POLY_API_SECRET
  api_secret = ""
  # Required. Set here or via env var POLY_PASSPHRASE
  passphrase = ""
  chain_id = 137
  enabled = true
  primary = true
  neg_risk = false

[api]
  clob_url = "https://clob.polymarket.com"
  gamma_url = "https://gamma-api.polymarket.com"
  data_url = "https://data-api.polymarket.com"
  ws_url = "wss://ws-subscriptions-clob.polymarket.com/ws/"
  timeout_sec = 10
  max_retries = 3

[trading]
  enabled = false
  max_position_usd = 100.0
  slippage_pct = 0.5
  default_order_type = "GTC"
  neg_risk = false
  [trading.strategies]
    [trading.strategies.arbitrage]
      enabled = false
      wallet_ids = ["0f5b5505285e5ac3"]
      min_profit_usd = 0.5
      max_position_usd = 100.0
      poll_interval_ms = 5000
      execute_orders = false
    [trading.strategies.market_making]
      enabled = false
      wallet_ids = ["0f5b5505285e5ac3"]
      spread_pct = 2.0
      max_position_usd = 200.0
      rebalance_interval_sec = 30
      min_liquidity_usd = 10000.0
      execute_orders = false
    [trading.strategies.positive_ev]
      enabled = false
      wallet_ids = ["0f5b5505285e5ac3"]
      min_edge_pct = 5.0
      min_liquidity_usd = 5000.0
      max_position_usd = 50.0
      poll_interval_ms = 30000
      execute_orders = false
    [trading.strategies.riskless_rate]
      enabled = false
      wallet_ids = ["0f5b5505285e5ac3"]
      min_duration_days = 30
      max_no_price = 0.05
      max_position_usd = 50.0
      poll_interval_ms = 60000
      execute_orders = false
    [trading.strategies.fade_chaos]
      enabled = false
      wallet_ids = ["0f5b5505285e5ac3"]
      spike_threshold_pct = 10.0
      cooldown_sec = 300
      max_position_usd = 50.0
      poll_interval_ms = 10000
      execute_orders = false
    [trading.strategies.cross_market]
      enabled = false
      wallet_ids = ["0f5b5505285e5ac3"]
      min_divergence_pct = 5.0
      max_position_usd = 75.0
      poll_interval_ms = 30000
      execute_orders = false
  [trading.risk]
    stop_loss_pct = 20.0
    take_profit_pct = 50.0
    max_daily_loss_usd = 100.0

[monitor]
  enabled = true
  poll_interval_ms = 1000
  markets = []
  [monitor.trades]
    enabled = true
    poll_interval_ms = 5000
    track_positions = true
    alert_on_fill = true
    alert_on_cancel = true
    trades_limit = 50

[telegram]
  enabled = false
  # Required if telegram.enabled = true. Env var: TELEGRAM_BOT_TOKEN
  bot_token = ""
  admin_chat_id = ""

[database]
  enabled = false
  path = "./data/orbitron.db"

[log]
  level = "info"
  format = "pretty"
  file = "./orbitron.log"

[copytrading]
  enabled = false
  poll_interval_ms = 10000
  size_mode = "proportional"
  traders = []

[ui]
  language = "en"

[webui]
  enabled = false
  listen = "127.0.0.1:8080"
  # Change this in production. Env var: WEBUI_JWT_SECRET
  jwt_secret = ""

[proxy]
  enabled = false
  type = ""
  addr = ""
  # Env var: POLY_PROXY_USERNAME
  username = ""
  # Env var: POLY_PROXY_PASSWORD
  password = ""
