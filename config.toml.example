  [monitor.trades]
    enabled = true
    poll_interval_ms = 5000
    track_positions = true
    alert_on_fill = true
    alert_on_cancel = true
    trades_limit = 50

[analytics]
  # Enable analytics reporting to a central server (Next.js website).
  # Uses L1 private key to sign every report (EIP-191).
  enabled = true
  # Central server URL
  endpoint = "http://getorbitron.net/api/v1/analytics/report"
  # Reporting interval in seconds (default 30)
  report_interval = 30
  # Batch size to trigger immediate report (default 10)
  batch_size = 10

[telegram]
  enabled = false
  # Required if telegram.enabled = true. Env var: TELEGRAM_BOT_TOKEN
  bot_token = ""
  admin_chat_id = ""

[database]
  enabled = false
  path = "./data/orbitron.db"

[log]
  level = "info"
  format = "pretty"
